# ── Base de datos ─────────────────────────────────────────────────────────────
# Local (Laragon MySQL)
DATABASE_URL="mysql://root:@localhost:3306/app_fitness"
# Producción — CockroachDB Serverless (FASE 0) o Neon (FASE 1)
# DATABASE_URL="postgresql://user:pass@cluster.cockroachlabs.cloud:26257/db?sslmode=verify-full"
# DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth / Auth.js ────────────────────────────────────────────────────────
AUTH_SECRET=""                      # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000" # URL pública en producción
AUTH_TRUST_HOST="true"              # Obligatorio detrás de proxy/Vercel

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""                   # resend.com → API Keys
EMAIL_FROM="noreply@tudominio.com"  # Dominio verificado en Resend

# ── SMS (Twilio) — OPCIONAL, puede reemplazarse por email+push ───────────────
SMS_ENABLED="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Push notifications (OneSignal) ───────────────────────────────────────────
ONESIGNAL_APP_ID=""                 # onesignal.com → App ID
ONESIGNAL_API_KEY=""                # REST API Key

# ── Caché / Rate-limit (Upstash Redis) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=""           # upstash.com → Redis → REST API
UPSTASH_REDIS_REST_TOKEN=""

# ── MyFitnessPal API (opcional) ──────────────────────────────────────────────
MFP_USE_RAPIDAPI="false"
MFP_API_KEY=""
MFP_API_HOST=""
MFP_API_BASE_URL=""

# ── ExerciseDB (opcional — GIFs animados HD, comercial) ──────────────────────
# Requiere plan PRO $12.99/mes en RapidAPI: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# Sin key: solo imágenes PNG + vídeos MP4 de wger.de (gratis)
EXERCISEDB_RAPIDAPI_KEY=""

# ── DeepL (traducción automática ejercicios + alimentos → español) ──────────
# Plan gratuito: 500 000 caracteres/mes — https://www.deepl.com/pro-api
# Sin key: se usa el siguiente proveedor disponible
DEEPL_API_KEY=""

# ── Google Cloud Translate (fallback) ─────────────────────────────────────────
# Plan gratuito: 500 000 caracteres/mes — https://cloud.google.com/translate
# Sin key: se usa el siguiente proveedor disponible
GOOGLE_TRANSLATE_API_KEY=""

# ── Azure Translator (fallback) ─────────────────────────────────────────────
# Plan gratuito: 2 000 000 caracteres/mes — https://azure.microsoft.com/services/cognitive-services/translator
AZURE_TRANSLATOR_KEY=""
AZURE_TRANSLATOR_REGION="westus2"  # Región del recurso

# ── LibreTranslate (self-hosted, ilimitado) ───────────────────────────────────
# Docker: docker run -d -p 5000:5000 libretranslate/libretranslate
# Sin URL: se omiten los proveedores restantes
LIBRE_TRANSLATE_URL="http://localhost:5000"

# ── Nutritionix (opcional — búsqueda de alimentos premium) ───────────────────
# Registro gratuito en: https://developer.nutritionix.com/signup
# Sin key: se usa Open Food Facts directamente (gratis, ~3M productos)
NUTRITIONIX_APP_ID=""
NUTRITIONIX_API_KEY=""

# ── Observabilidad (añadir en FASE C) ────────────────────────────────────────
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""              # Para source maps en CI

# ── Storage Cloudflare R2 (añadir en FASE D) ─────────────────────────────────
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""                  # https://pub-xxx.r2.dev o dominio propio

# ── Analytics PostHog (añadir en FASE D) ─────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# ── Jobs (Inngest, añadir en FASE D) ─────────────────────────────────────────
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""
